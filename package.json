{
  "name": "yt-mp3-downloader",
  "version": "1.0.0",
  "description": "Descargador de audio desde YouTube con interfaz de terminal interactiva",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "clean": "rimraf dist",
    "flush": "node dist/index.js --flush-hdir"
  },
  "keywords": [
    "youtube",
    "mp3",
    "downloader",
    "yt-dlp",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "terminal-kit": "^3.1.1",
    "yt-dlp-exec": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}